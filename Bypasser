-- Manual toggle lag
local function manualToggle()
	if autoOn then return end  -- auto mode controls activation
	if not activated then
		activated = true
		enableBtn.Text = "Disable"
		enableBtn.BackgroundColor3 = Color3.fromRGB(200, 70, 70)
		startLag()
	else
		stopLag()
		enableBtn.Text = "Enable"
		enableBtn.BackgroundColor3 = Color3.fromRGB(140, 70, 200)
	end
end

enableBtn.MouseButton1Click:Connect(manualToggle)

-- Auto Steal toggle
local function toggleAuto()
	autoOn = not autoOn
	if autoOn then
		autoBtn.Text = "On"
		autoBtn.BackgroundColor3 = Color3.fromRGB(70, 200, 70)
		modeBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 70)  -- disabled look
		modeBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
		modeBtn.Active = false
		enableBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
		enableBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
		enableBtn.Active = false
		-- If currently lag is on, turn it off (auto will control)
		if activated then stopLag() end
		-- start auto monitoring
		if not autoConn then
			autoConn = RunService.Heartbeat:Connect(function()
				if not autoOn then return end
				local char = lp.Character
				if not char then return end
				local hum = char:FindFirstChildOfClass("Humanoid")
				if not hum then return end
				-- Detect stealing: WalkSpeed < 25 (typical carry state)
				local isStealing = hum.WalkSpeed < 25
				if isStealing then
					-- Ensure we are in ping lagger mode and lag is on
					if currentMode ~= "PingLagger" then
						setMode("PingLagger")
					end
					if not activated then
						activated = true
						startLag()
						enableBtn.Text = "Disable"  -- visual sync
						enableBtn.BackgroundColor3 = Color3.fromRGB(200, 70, 70)
					end
				else
					-- Not stealing: turn off lag and revert to normal
					if activated then
						stopLag()
						enableBtn.Text = "Enable"
						enableBtn.BackgroundColor3 = Color3.fromRGB(140, 70, 200)
					end
					if currentMode ~= "Normal" then
						setMode("Normal")
					end
				end
			end)
		end
	else
		autoBtn.Text = "Off"
		autoBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
		modeBtn.BackgroundColor3 = Color3.fromRGB(140, 70, 200)
		modeBtn.TextColor3 = Color3.new(1, 1, 1)
		modeBtn.Active = true
		enableBtn.BackgroundColor3 = Color3.fromRGB(140, 70, 200)
		enableBtn.TextColor3 = Color3.new(1, 1, 1)
		enableBtn.Active = true
		if autoConn then
			autoConn:Disconnect()
			autoConn = nil
		end
		-- If lag is still on, turn it off (manual control now)
		if activated then stopLag(); enableBtn.Text = "Enable"; enableBtn.BackgroundColor3 = Color3.fromRGB(140, 70, 200) end
	end
end
autoBtn.MouseButton1Click:Connect(toggleAuto)

-- Input listener (only for manual toggle if not auto)
UserInputService.InputBegan:Connect(function(input, gpe)
	if gpe then return end
	if waitingForKey then
		if input.UserInputType == Enum.UserInputType.Keyboard then
			keybind = input.KeyCode
			kbBtn.Text = keybind.Name
			kbBtn.BackgroundColor3 = Color3.fromRGB(140, 70, 200)
			waitingForKey = false
		end
		return
	end
	if input.KeyCode == keybind then
		manualToggle()  -- uses the same function that respects autoOn
	end
end)

-- Ping monitoring for warning
pingCheckConn = RunService.Heartbeat:Connect(function()
	if activated and currentMode == "PingLagger" then
		local ping = lp:GetNetworkPing()  -- in milliseconds
		if ping > 100 then
			warning.Visible = true
			warning.Text = "⚠️High Ping " .. math.floor(ping) .. " Turn Off⚠️"
		else
			warning.Visible = false
		end
	else
		warning.Visible = false
	end
end)

-- Re-apply on respawn (if manual mode is on, auto will handle itself)
lp.CharacterAdded:Connect(function()
	task.wait(1)
	if not autoOn then
		-- Only re-apply manual lag if it was on
		if activated then
			stopLag()
			activated = true
			startLag()
		end
	end
	-- If auto is on, the heartbeat will detect the new character and apply state.
end)

